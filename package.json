{
  "dependencies": {
    "iitc-kuku-plugin-tester": "^1.0.1",
    "iitcpluginkit": "^1.9.6"
  },
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "build": "yarn build:dev",
    "build:dev": "yarn ipk build:dev",
    "build:prod": "yarn ipk build:prod",
    "start": "yarn ipk fileserver",
    "autobuild": "yarn ipk autobuild",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:e2e:update": "playwright test --config playwright.e2e.config.ts --update-snapshots"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "express": "^4.18.2",
    "handlebars": "^4.7.8",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.1.0"
  }
}

{{#if focusedAgent}}
<div class="agents-focus-bar">
    Highlighting: <strong>{{focusedAgent}}</strong>
    &nbsp;
    <button onclick="{{plugin}}.clearFocusedAgent()">Clear</button>
</div>
{{/if}}
<table class="inventoryTable agents-table">
    <thead>
        <tr>
            <th>Focus</th>
            <th>Agent</th>
            <th>Imported</th>
            <th>Portals</th>
            <th>Keys</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        {{#each agents}}
            <tr{{#if this.focused}} class="agent-row-focused"{{/if}}>
                <td>
                    {{#unless this.focused}}
                        <button onclick="{{../plugin}}.setFocusedAgent('{{this.name}}')">
                            Focus
                        </button>
                    {{/unless}}
                </td>
                <td><strong>{{this.name}}</strong></td>
                <td style="font-size: 0.85em">{{this.importedAt}}</td>
                <td class="cnt">{{this.keyPortals}}</td>
                <td class="cnt">{{this.keyCount}}</td>
                <td>
                    <button onclick="{{../plugin}}.deleteAgent('{{../teamId}}', '{{this.name}}')">
                        Remove
                    </button>
                </td>
            </tr>
        {{/each}}
    </tbody>
</table>
